# Master .gitignore for IVR Regulator

# Dependency directories
**/node_modules/

# Local environment files (containing secret keys and credentials)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Frontend production builds
**/dist/
**/build/

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata
.DS_Store
Thumbs.db

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log
